{
  "name": "@swifty.js/sentry",
  "version": "0.0.1",
  "description": "sentry sdk",
  "keywords": [
    "sdk",
    "sentry"
  ],
  "homepage": "https://github.com/hangtiancheng/swifty-sentry/tree/main/sentry#readme",
  "bugs": {
    "url": "https://github.com/hangtiancheng/swifty-sentry/issues"
  },
  "license": "MIT",
  "author": "https://github.com/hangtiancheng",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hangtiancheng/swifty-sentry.git",
    "directory": "sentry"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./plugins": {
      "types": "./dist/plugins/index.d.ts",
      "import": "./dist/plugins/index.js",
      "require": "./dist/plugins/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./preact": {
      "types": "./dist/preact.d.ts",
      "import": "./dist/preact.js",
      "require": "./dist/preact.cjs"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "import": "./dist/vue.js",
      "require": "./dist/vue.cjs"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js",
      "require": "./dist/vite.cjs"
    },
    "./webpack": {
      "types": "./dist/webpack.d.ts",
      "import": "./dist/webpack.js",
      "require": "./dist/webpack.cjs"
    }
  },
  "scripts": {
    "test": "vitest run --config ./vitest.config.ts",
    "test:watch": "vitest --config ./vitest.config.ts",
    "test:coverage": "vitest run --config ./vitest.config.ts --coverage",
    "typecheck": "tsc --noEmit",
    "vite7": "pnpm add -D vite7@npm:vite@7.3.3",
    "format": "oxfmt --write ./",
    "build": "rollup -c ./rollup.config.ts",
    "build:tsup": "tsup --config ./tsup.config.ts"
  },
  "dependencies": {
    "@fingerprintjs/fingerprintjs": "^5.2.0",
    "@rrweb/record": "2.1.0",
    "pako": "^2.2.0",
    "ua-parser-js": "^2.0.10",
    "web-vitals": "^5.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@rrweb/record": "2.1.0",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.9.4",
    "@types/pako": "^2.0.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^1.6.1",
    "jsdom": "^24.1.3",
    "oxfmt": "^0.54.0",
    "preact": "^10.29.7",
    "react": "^19.2.7",
    "rollup": "^4.62.2",
    "rollup-plugin-dts": "^6.4.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vite7": "npm:vite@7.3.3",
    "vitest": "^1.6.1",
    "vue": "^3.5.39",
    "webpack": "^5.108.3",
    "webpack-dev-server": "^5.2.6"
  },
  "peerDependencies": {
    "preact": "^10.0.0",
    "react": "^19.0.0",
    "vite": "^7.0.0 || ^8.0.0",
    "vue": "^3.0.0",
    "webpack": "^4.0.0 || ^5.0.0"
  },
  "peerDependenciesMeta": {
    "preact": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "vite": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "webpack": {
      "optional": true
    },
    "webpack-dev-server": {
      "optional": true
    }
  }
}
